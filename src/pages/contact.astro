---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — InciKorea">
  <div class="container py-16">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Get in Touch</h1>

    <div style="max-width: 600px; line-height: 1.8;">
      <p style="margin-bottom: 2rem;">Have questions about CLUNA, our products, or K-beauty regulatory compliance? We'd love to hear from you.</p>

      <div style="background: #f0f7ff; padding: 2rem; border-radius: 0.5rem; margin-bottom: 2rem;">
        <h2 style="font-size: 1.3rem; margin-bottom: 1rem;">Contact Information</h2>
        <p><strong>Email:</strong> <a href="mailto:hello@incikorea.com">hello@incikorea.com</a></p>
        <p><strong>Location:</strong> UK-based (London area)</p>
        <p><strong>Business Hours:</strong> Monday-Friday, 09:00-17:00 GMT</p>
      </div>

      <h2 style="font-size: 1.3rem; margin: 2rem 0 1rem 0;">What We Can Help With</h2>
      <ul style="margin-left: 2rem; margin-bottom: 2rem;">
        <li>Product inquiries and bulk ordering</li>
        <li>Retailer partnerships and distribution</li>
        <li>Regulatory compliance questions</li>
        <li>K-beauty market entry consulting</li>
        <li>General INCI and ingredient education</li>
      </ul>

      <h2 style="font-size: 1.3rem; margin: 2rem 0 1rem 0;">Press & Media</h2>
      <p>For press inquiries, product reviews, or media partnerships, please contact us directly. We're happy to provide product samples, interviews, and high-resolution imagery.</p>

      <h2 style="font-size: 1.3rem; margin: 2rem 0 1rem 0;">Social & Updates</h2>
      <p>Follow us for product launches, ingredient deep-dives, and K-beauty insights:</p>
      <ul style="margin-left: 2rem;">
        <li><a href="#">Instagram</a></li>
        <li><a href="#">Twitter</a></li>
        <li><a href="#">LinkedIn</a></li>
      </ul>
    </div>
  </div>
</Base>
