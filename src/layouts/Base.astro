---
interface Props {
  title?: string;
}

const { title = 'InciKorea' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="InciKorea — Premium K-Beauty Import Guide for UK market" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; line-height: 1.6; color: #333; }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
      h1, h2, h3 { font-weight: 700; margin-bottom: 0.5rem; }
      a { color: #0066cc; }
      a:hover { text-decoration: underline; }
      header { background: #f5f6fa; padding: 1rem 0; border-bottom: 1px solid #e0e0e0; }
      nav { display: flex; gap: 1rem; }
      footer { background: #f5f6fa; padding: 2rem 0; border-top: 1px solid #e0e0e0; margin-top: 4rem; }
      main { min-height: 70vh; }
      .py-12 { padding: 3rem 0; }
      .py-16 { padding: 4rem 0; }
      .mb-4 { margin-bottom: 1rem; }
      .mb-8 { margin-bottom: 2rem; }
      .mt-4 { margin-top: 1rem; }
    </style>
  </head>
  <body>
    <header>
      <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
        <h1><a href="/">🇰🇷 InciKorea</a></h1>
        <nav>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>&copy; 2026 InciKorea. All rights reserved. | INCI-compliant K-beauty for UK & Europe</p>
      </div>
    </footer>
  </body>
</html>
